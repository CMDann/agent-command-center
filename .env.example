# GitHub personal access token (PAT)
# Optional for public repos, but recommended to avoid rate limits.
# Fine-grained PAT permissions (minimum):
# - Repository permissions: Issues (Read), Pull requests (Read), Metadata (Read)
# - Optional for PR checks status: Commit statuses (Read)
GITHUB_TOKEN=

# GitHub repository coordinates used by GitHubService
GITHUB_OWNER=
GITHUB_REPO=

# Remote agent bridge authentication
#
# Preferred (supports multiple token IDs, secrets never sent over the wire):
# Comma-separated list of tokenId=secret pairs.
# Example: NEXUS_BRIDGE_TOKENS=openclaw-1=supersecret,ci=anothersecret
NEXUS_BRIDGE_TOKENS=
#
# Legacy single-token secret (fallback for early prototypes). Prefer TOKENS above.
NEXUS_BRIDGE_SECRET=
