# GitHub personal access token (PAT)
# Optional for public repos, but recommended to avoid rate limits.
# Fine-grained PAT permissions (minimum):
# - Repository permissions: Issues (Read), Pull requests (Read), Metadata (Read)
# - Optional for PR checks status: Commit statuses (Read)
GITHUB_TOKEN=

# GitHub repository coordinates used by GitHubService
GITHUB_OWNER=
GITHUB_REPO=

# Shared secret for authenticating remote agent bridge connections
NEXUS_BRIDGE_SECRET=
